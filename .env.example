# ──────────────────────────────────────────────────────────────
#  Conexion a Supabase PostgreSQL (Transaction / Session Pooler)
# ──────────────────────────────────────────────────────────────
# Usar Transaction Pooler (puerto 6543) o Session Pooler (puerto 5432).
# Reemplazar <PROJECT_REF> y <PASSWORD> con los valores reales.
# NO subir la contraseña real al repositorio.
#
# Formato:
#   DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
#
# Para desarrollo local (PostgreSQL local):
#   DATABASE_URL=postgresql://postgres:123456789@localhost:5432/bd_core_mobile
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/bd_core_mobile

# JWT
SECRET_KEY=cambia_esta_clave
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# URL del nucleo bancario (solo para sync_outbox -> core)
CORE_BACKEND_URL=http://localhost:8001

# Puerto del servidor FastAPI
PORT=8003
