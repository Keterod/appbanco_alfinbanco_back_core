# ──────────────────────────────────────────────────────────────
#  Core Mobile — Variables de entorno
# ──────────────────────────────────────────────────────────────

# Conexion a PostgreSQL (Render, Supabase o local).
# Render Postgres incluye ?sslmode=require automaticamente.
# Para desarrollo local sin SSL:
#   DATABASE_URL=postgresql://postgres:123456789@localhost:5432/bd_core_mobile
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/bd_core_mobile

# Modo SSL para la BD principal. Valores validos: require, disable, allow, prefer.
# Render/Supabase: require. Local sin SSL: disable (o vacio).
DB_USE_SSL=require

# JWT
SECRET_KEY=cambia_esta_clave_por_una_larga_y_aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# URL del nucleo bancario (solo para sync_outbox -> core)
CORE_BACKEND_URL=http://localhost:8001

# BD del nucleo bancario para el puente de promocion (sync_outbox -> core)
CORE_DATABASE_URL=postgresql://postgres:123456789@localhost:5432/bd_core_financiero
CORE_DB_USE_SSL=require

# Puerto del servidor FastAPI.
# Render sobreescribe esta variable con el puerto asignado automaticamente.
PORT=8003
